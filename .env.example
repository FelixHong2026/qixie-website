# 齐谐科技 — 部署环境变量
# 复制此文件为 .env 并填入实际值

# 域名
DOMAIN=felix2026.cc.cd
OPENCLAW_DOMAIN=openclaw.qixie.tech

# SSL 邮箱 (Let's Encrypt)
SSL_EMAIL=admin@qixie.tech

# 部署服务器
DEPLOY_HOST=192.168.1.223
DEPLOY_USER=felix
DEPLOY_PATH=/home/felix/qixie

# Docker 镜像仓库 (可选, 默认使用本地构建)
# REGISTRY=ghcr.io/felix2026

# ----- CMP-129 全栈集成后使用 -----

# 数据库 (PostgreSQL)
DB_PASSWORD=changeme_strong_password_here
POSTGRES_DB=qixie
POSTGRES_USER=qixie

# API 配置
API_PORT=8000
# CORS 来源 (生产域名)
CORS_ORIGINS=https://felix2026.cc.cd

# AI 服务 (GLM-4-Flash)
# GLM_API_KEY=
# GLM_MODEL=glm-4-flash

# Azure TTS
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_REGION=eastasia

# PayPal
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_MODE=sandbox
